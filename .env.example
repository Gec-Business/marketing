# Database
DATABASE_URL=postgresql://marketing:mk_gec_2026_secure@localhost:5432/marketing_db

# Auth
SESSION_SECRET=at-least-32-characters-long-random-string-here
ADMIN_PASSWORD=change-this-admin-password

# Encryption (used to encrypt API keys at rest in DB)
# Generate with: openssl rand -base64 32
# WARNING: rotating this makes all encrypted API keys unrecoverable
ENCRYPTION_KEY=at-least-32-characters-long-random-string-here

# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (DALL-E image generation)
OPENAI_API_KEY=sk-...

# Google Maps
GOOGLE_MAPS_API_KEY=AIza...

# App
APP_URL=https://mk.gecbusiness.com
CRON_SECRET=random-cron-secret-here
UPLOAD_DIR=/var/www/marketing/uploads

# Meta (Facebook + Instagram)
META_APP_ID=
META_APP_SECRET=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ORG_ID=

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Email alerts (Resend - https://resend.com - 3000 free emails/month)
RESEND_API_KEY=
RESEND_FROM=MK Platform <alerts@mk.gecbusiness.com>
ALERT_EMAIL=it@gecbusiness.com
